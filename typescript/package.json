{
  "name": "symphony",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "bun run src/cli/index.ts",
    "symphony": "bun run src/cli/index.ts",
    "build": "bun build src/cli/index.ts --outfile dist/symphony --target bun",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "verify": "bun run typecheck && bun run test",
    "plane:check": "bun run src/dev/plane.ts check",
    "plane:workflow": "bun run src/dev/plane.ts workflow",
    "plane:up": "bun run src/dev/plane.ts up",
    "plane:down": "bun run src/dev/plane.ts down",
    "plane:status": "bun run src/dev/plane.ts status",
    "plane:dev": "bun run src/dev/plane.ts run"
  },
  "dependencies": {
    "effect": "4.0.0-beta.43",
    "@effect/platform-bun": "4.0.0-beta.43",
    "liquidjs": "^10.25.2",
    "yaml": "^2.8.3",
    "chokidar": "^4.0.3",
    "hono": "^4.12.10"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "@types/bun": "^1.3.11",
    "vitest": "^3.2.4",
    "@effect/vitest": "4.0.0-beta.43"
  }
}
